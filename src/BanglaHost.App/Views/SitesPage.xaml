<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="BanglaHost.App.Views.SitesPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:BanglaHost.App.Views"
    xmlns:vm="using:BanglaHost.App.ViewModels">

    <Grid x:Name="RootGrid" Padding="24" RowSpacing="16" DataContext="{x:Bind ViewModel}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Sites" FontSize="26" FontWeight="SemiBold"/>
        
        <InfoBar Grid.Row="1" IsOpen="{Binding StatusOpen, Mode=TwoWay}" Message="{Binding StatusMessage}" Severity="{Binding StatusSeverity}" />

        <Border Grid.Row="2" BorderThickness="1" CornerRadius="8" Padding="12"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
            <StackPanel Spacing="10">
                <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                    <TextBox Text="{Binding NewSiteName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" PlaceholderText="Site name (e.g. myapp)" Width="180"/>
                    <ComboBox Header="PHP" ItemsSource="{Binding PhpVersions}" SelectedItem="{Binding SelectedPhp, Mode=TwoWay}" Width="100"/>
                    <ComboBox Header="CMS / Type" ItemsSource="{Binding CmsOptions}" SelectedItem="{Binding SelectedCms, Mode=TwoWay}" MinWidth="130"/>
                    <ComboBox Header="Server" ItemsSource="{Binding WebServers}" SelectedItem="{Binding SelectedWebServer, Mode=TwoWay}" Width="100"/>
                    <CheckBox Content="HTTPS" IsChecked="{Binding EnableHttps, Mode=TwoWay}" VerticalAlignment="Bottom" Margin="0,0,0,8"/>
                    
                    <Button Content="Add site" Command="{Binding AddSiteCommand}" Style="{StaticResource AccentButtonStyle}" VerticalAlignment="Bottom"/>
                    <ProgressRing IsActive="{Binding IsBusy}" Width="20" Height="20" Margin="10,0,0,0" VerticalAlignment="Center"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Spacing="8" Visibility="{x:Bind local:SitesPage.BoolToVis(ViewModel.IsCustomMode), Mode=OneWay}">
                    <TextBox Text="{Binding CustomRootPath, Mode=TwoWay}" PlaceholderText="Project folder path" Width="420" IsReadOnly="True"/>
                    <Button Content="Browse…" Command="{Binding BrowseFolderCommand}" VerticalAlignment="Bottom"/>
                    <TextBlock Text="Point at any existing project folder — nothing is overwritten." Opacity="0.65" VerticalAlignment="Center" TextWrapping="Wrap" MaxWidth="280"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <Border Grid.Row="3" BorderThickness="1" CornerRadius="8" Padding="4"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
            <Grid>
                <TextBlock Text="No sites yet. Add one above."
                           Visibility="{x:Bind local:SitesPage.BoolToVis(ViewModel.IsEmpty), Mode=OneWay}"
                           VerticalAlignment="Center" HorizontalAlignment="Center" Opacity="0.6"/>
                <ListView x:Name="SitesListView" ItemsSource="{Binding Sites}" Tag="{Binding}" SelectionMode="None"
                          Visibility="{x:Bind local:SitesPage.BoolToVisInverse(ViewModel.IsEmpty), Mode=OneWay}">
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="vm:SiteListItem">
                            <Grid Padding="8,6" ColumnSpacing="10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="200"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                
                                <TextBlock Grid.Column="0" Text="{x:Bind SiteName}" FontWeight="SemiBold" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                <HyperlinkButton Grid.Column="1" Content="{x:Bind Url}" NavigateUri="{x:Bind Url}" VerticalAlignment="Center"/>
                                
                                <Border Grid.Column="2" VerticalAlignment="Center" CornerRadius="4" Padding="7,2" Margin="0,0,6,0"
                                        Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}">
                                    <TextBlock Text="{x:Bind Badge}" FontSize="11" Opacity="0.8"/>
                                </Border>
                                
                                <StackPanel Grid.Column="3" Orientation="Horizontal" Spacing="4">
                                    <Button Command="{Binding Path=Tag.FixHostsCommand, ElementName=SitesListView}" CommandParameter="{x:Bind}" ToolTipService.ToolTip="Fix DNS (hosts file)">
                                        <FontIcon Glyph="&#xE774;" FontSize="14"/>
                                    </Button>
                                    <Button Command="{Binding Path=Tag.EditSiteCommand, ElementName=SitesListView}" CommandParameter="{x:Bind}" ToolTipService.ToolTip="Edit">
                                        <FontIcon Glyph="&#xE70F;" FontSize="14"/>
                                    </Button>
                                    <Button Command="{Binding Path=Tag.DeleteSiteCommand, ElementName=SitesListView}" CommandParameter="{x:Bind}" ToolTipService.ToolTip="Delete">
                                        <FontIcon Glyph="&#xE74D;" FontSize="14"/>
                                    </Button>
                                </StackPanel>
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Grid>
        </Border>
    </Grid>
</Page>
