<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="BanglaHost.App.Views.RuntimesPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Loaded="Page_Loaded">
    <StackPanel Padding="24" Spacing="16">
        <StackPanel Spacing="2">
            <TextBlock Text="Runtimes &amp; Containers" FontSize="26" FontWeight="SemiBold"/>
            <TextBlock Opacity="0.7" Text="Check system status for Go, Rust, and Docker."/>
        </StackPanel>

        <Border BorderThickness="1" CornerRadius="8" Padding="16"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
            <StackPanel Spacing="16">
                
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="100"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Go:" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    <TextBlock x:Name="GoVersionText" Grid.Column="1" Text="Checking..." VerticalAlignment="Center" Opacity="0.8"/>
                    <Button Grid.Column="2" Content="Download Go" Click="DownloadGo_Click"/>
                </Grid>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="100"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Rust (cargo):" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    <TextBlock x:Name="RustVersionText" Grid.Column="1" Text="Checking..." VerticalAlignment="Center" Opacity="0.8"/>
                    <Button Grid.Column="2" Content="Download Rust" Click="DownloadRust_Click"/>
                </Grid>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="100"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Docker:" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    <TextBlock x:Name="DockerVersionText" Grid.Column="1" Text="Checking..." VerticalAlignment="Center" Opacity="0.8"/>
                    <Button Grid.Column="2" Content="Download Docker" Click="DownloadDocker_Click"/>
                </Grid>

                <StackPanel Orientation="Horizontal" Margin="0,16,0,0">
                    <Button Content="Refresh Status" Click="Refresh_Click"/>
                    <ProgressRing x:Name="Busy" IsActive="False" Width="20" Height="20" Margin="10,0,0,0"/>
                </StackPanel>
            </StackPanel>
        </Border>
    </StackPanel>
</Page>
